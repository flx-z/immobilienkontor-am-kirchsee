---
import '../styles/brand.css';
import '../styles/typography.css';
import CookieBanner from '../components/utility/CookieBanner.astro';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Immobilienkontor am Kirchsee', description = '' } = Astro.props;
---
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
  </head>
  <body class="bg-[var(--color-bg)] text-[var(--color-text)]">
    <slot />
    <CookieBanner
      text="Diese Website verwendet Cookies, um Ihnen die bestmögliche Nutzererfahrung zu bieten."
      acceptLabel="Alle akzeptieren"
      declineLabel="Nur notwendige"
      privacyLink={{ label: "Datenschutzerklärung", href: "/datenschutz" }}
    />
    <script>
      (() => {
        const setVisible = (el) => el.classList.add('is-visible');
        const targets = Array.from(document.querySelectorAll('.animate-on-scroll, .animate-item'));
        const pending = new Set(targets);
        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        // Avoid :scope selector issues on some mobile browsers.
        document.querySelectorAll('.animate-stagger').forEach((group) => {
          const items = Array.from(group.children).filter((child) => child.classList.contains('animate-item'));
          items.forEach((item, index) => {
            if (!item.style.getPropertyValue('--reveal-delay')) {
              item.style.setProperty('--reveal-delay', `${Math.min(index * 90, 720)}ms`);
            }
          });
        });

        const isInViewport = (el) => {
          const rect = el.getBoundingClientRect();
          const vh = window.innerHeight || document.documentElement.clientHeight;
          return rect.top <= vh * 0.92 && rect.bottom >= 0;
        };

        let observer = null;
        const markVisible = (el) => {
          if (!pending.has(el)) return;
          setVisible(el);
          pending.delete(el);
          if (observer) observer.unobserve(el);
        };

        if (prefersReducedMotion) {
          targets.forEach(markVisible);
          return;
        }

        if ('IntersectionObserver' in window) {
          observer = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                markVisible(entry.target);
              }
            });
          }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });

          targets.forEach((el) => observer.observe(el));
        }

        let rafId = 0;
        const checkPending = () => {
          rafId = 0;
          pending.forEach((el) => {
            if (isInViewport(el)) markVisible(el);
          });

          if (!pending.size) {
            window.removeEventListener('scroll', onScroll);
            window.removeEventListener('resize', onScroll);
            if (observer) observer.disconnect();
          }
        };

        const onScroll = () => {
          if (rafId) return;
          rafId = window.requestAnimationFrame(checkPending);
        };

        // Initial check and mobile fallback without killing the reveal for off-screen content.
        checkPending();
        window.addEventListener('scroll', onScroll, { passive: true });
        window.addEventListener('resize', onScroll);
        window.setTimeout(checkPending, 1200);
      })();
    </script>
  </body>
</html>
