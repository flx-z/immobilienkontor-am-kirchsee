---
import BaseLayout from '../layouts/BaseLayout.astro';
import NavStandard from '../components/core/NavStandard.astro';
import HeroCentered from '../components/core/HeroCentered.astro';
import FeaturesAlternating from '../components/core/FeaturesAlternating.astro';
import ProcessSteps from '../components/core/ProcessSteps.astro';
import FAQAccordion from '../components/standard/FAQAccordion.astro';
import CTABanner from '../components/core/CTABanner.astro';
import FooterStandard from '../components/core/FooterStandard.astro';

import beratungImg from '../assets/images/beratung_handschlag.jpg';
---
<BaseLayout
  title="Leistungen beim Immobilienverkauf – Immobilienkontor am Kirchsee"
  description="Strategische Immobilienvermittlung in Preetz und Kiel: Ausschließlich für Verkäufer, ohne Käuferprovision. Strukturiert, transparent und mit messbarem Ergebnis."
>
  <NavStandard
    logo="/logo.svg"
    logoAlt="Immobilienkontor am Kirchsee Logo"
    logoHeight={48}
    links={[
      { label: "Start", href: "/" },
      { label: "Leistungen", href: "/leistungen" },
      { label: "Ihr Vorteil", href: "/ihr-vorteil" },
      { label: "Über uns", href: "/ueber-uns" },
      { label: "Tippgeber", href: "/tippgeber" },
      { label: "Kontakt", href: "/kontakt" }
    ]}
    cta={{ text: "Beratungsgespräch anfragen", href: "/kontakt" }}
  />

  <HeroCentered
    headline="Immobilien verkaufen – mit System."
    subline="Kein Zufall, keine Kompromisse: Wir steuern Ihren Verkaufsprozess strategisch von Anfang bis Ende."
    primaryCta={{ text: "Jetzt Gespräch vereinbaren", href: "/kontakt" }}
    backgroundVariant="dark"
  />

  <FeaturesAlternating
    features={[
      {
        title: "Ausschließlich auf Ihrer Seite",
        text: "Wir übernehmen keine Mandate für Käufer. Das bedeutet: Jede Entscheidung, jede Empfehlung und jede Verhandlungsstrategie ist ausschließlich auf Ihren wirtschaftlichen Vorteil ausgerichtet. Interessenkonflikte sind strukturell ausgeschlossen.",
        cta: { label: "Erstgespräch anfragen", href: "/kontakt" },
        image: { src: beratungImg, alt: "Persönliche Beratung und Handschlag bei der Immobilienübergabe" }
      },
      {
        title: "Jede Immobilie ist ein Einzelfall",
        text: "Wir entwickeln für jedes Objekt eine individuelle Verkaufsstrategie. Marktumfeld, Objekteigenschaften, Zielgruppe und Timing werden aufeinander abgestimmt – für ein optimales Ergebnis unter realen Marktbedingungen.",
        cta: { label: "Vorteil berechnen", href: "/ihr-vorteil" },
        image: { src: "", alt: "" }
      },
      {
        title: "Sie entscheiden – wir strukturieren",
        text: "In jeder Phase des Verkaufs behalten Sie die Kontrolle. Wir bereiten alle relevanten Informationen verständlich auf, erläutern Optionen und deren Konsequenzen – und treffen Entscheidungen gemeinsam mit Ihnen.",
        image: { src: "", alt: "" }
      }
    ]}
  />

  <ProcessSteps
    headline="Unser Verkaufsprozess im Überblick"
    subline="Strukturiert, nachvollziehbar und konsequent auf Ihr Ergebnis ausgerichtet."
    steps={[
      { title: "Analyse & Erstgespräch", text: "Wir verstehen Ihre Situation, Ihre Immobilie und Ihre Ziele – bevor wir irgendetwas empfehlen." },
      { title: "Marktbewertung & Strategie", text: "Realistische Marktpreisermittlung und Entwicklung der individuellen Verkaufsstrategie." },
      { title: "Professionelle Vermarktung", text: "Gezielte Ansprache finanzierungsfähiger Käufer – ohne Provisionshürde, mit maximaler Reichweite." },
      { title: "Verhandlung & Abschluss", text: "Wir führen Verhandlungen konsequent in Ihrem Interesse und begleiten Sie bis zum notariellen Abschluss." }
    ]}
    backgroundVariant="dark"
  />

  <FAQAccordion
    headline="Fragen zu unseren Leistungen"
    items={[
      { question: "Für welche Immobilientypen sind Sie zuständig?", answer: "Wir begleiten den Verkauf von Eigentumswohnungen, Einfamilienhäusern, Mehrfamilienhäusern und Grundstücken in der Region Preetz, Kiel und Umgebung." },
      { question: "Wie läuft das erste Beratungsgespräch ab?", answer: "Das Erstgespräch ist unverbindlich und kostenlos. Wir lernen Ihre Immobilie und Ihre Erwartungen kennen, erläutern unseren Ansatz und beantworten alle Fragen – ohne Verkaufsdruck." },
      { question: "Wie lange dauert ein typischer Verkaufsprozess?", answer: "Das hängt von Objekt, Lage und Marktumfeld ab. Durch den Wegfall der Käuferprovision und die gezielte Vermarktung sind Verkaufsprozesse in der Regel effizienter als im klassischen Modell." },
      { question: "Übernehmen Sie auch die Kommunikation mit Kaufinteressenten?", answer: "Ja. Wir koordinieren alle Besichtigungen, führen Gespräche mit Interessenten und halten Sie regelmäßig auf dem Laufenden – strukturiert und ohne unnötigen Aufwand für Sie." }
    ]}
    backgroundVariant="light"
  />

  <CTABanner
    headline="Starten Sie jetzt mit einem unverbindlichen Erstgespräch."
    subline="Wir analysieren Ihre Ausgangslage und zeigen Ihnen, welchen wirtschaftlichen Vorteil unser Ansatz für Sie bedeutet."
    primaryCta={{ label: "Beratung anfragen", href: "/kontakt" }}
    backgroundVariant="dark"
  />

  <FooterStandard
    logo={{ src: "/logo.svg", alt: "Immobilienkontor am Kirchsee Logo", height: 56 }}
    description="Konsequent auf Ihrer Seite."
    columns={[
      {
        headline: "Leistungen",
        links: [
          { label: "Immobilien verkaufen", href: "/leistungen" },
          { label: "Ihr wirtschaftlicher Vorteil", href: "/ihr-vorteil" },
          { label: "Tippgeber-Programm", href: "/tippgeber" }
        ]
      },
      {
        headline: "Unternehmen",
        links: [
          { label: "Über uns", href: "/ueber-uns" },
          { label: "Kontakt", href: "/kontakt" }
        ]
      }
    ]}
    contact={{ address: "Lange Brückstraße 28, 24211 Preetz" }}
    legalLinks={[
      { label: "Impressum", href: "/impressum" },
      { label: "Datenschutz", href: "/datenschutz" }
    ]}
    copyright="© 2026 Immobilienkontor am Kirchsee. Alle Rechte vorbehalten."
  />
</BaseLayout>
