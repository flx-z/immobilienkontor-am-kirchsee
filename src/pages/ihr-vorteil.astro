---
import BaseLayout from '../layouts/BaseLayout.astro';
import NavStandard from '../components/core/NavStandard.astro';
import HeroCentered from '../components/core/HeroCentered.astro';
import ContentParagraph from '../components/core/ContentParagraph.astro';
import FeaturesGrid from '../components/core/FeaturesGrid.astro';
import ContentQuote from '../components/standard/ContentQuote.astro';
import CTABanner from '../components/core/CTABanner.astro';
import FooterStandard from '../components/core/FooterStandard.astro';

import portraitImg from '../assets/images/portrait_marcel_ziebell.jpg';
---
<BaseLayout
  title="Ihr Vorteil beim Verkauf – Immobilienkontor am Kirchsee | Preetz"
  description="Wie der Wegfall der Käuferprovision mehr Nachfrage und bessere Verkaufspreise erzeugt. Jetzt verstehen, was das konkret für Ihre Immobilie bedeutet."
>
  <NavStandard
    logo="/logo.svg"
    logoAlt="Immobilienkontor am Kirchsee Logo"
    logoHeight={48}
    links={[
      { label: "Start", href: "/" },
      { label: "Leistungen", href: "/leistungen" },
      { label: "Ihr Vorteil", href: "/ihr-vorteil" },
      { label: "Über uns", href: "/ueber-uns" },
      { label: "Tippgeber", href: "/tippgeber" },
      { label: "Kontakt", href: "/kontakt" }
    ]}
    cta={{ text: "Beratungsgespräch anfragen", href: "/kontakt" }}
  />

  <HeroCentered
    headline="Ihr wirtschaftlicher Vorteil – konkret."
    subline="Wie der Wegfall der Käuferprovision Nachfrage erhöht, Wettbewerb steigert und Ihren Verkaufspreis verbessert."
    primaryCta={{ text: "Jetzt Gespräch vereinbaren", href: "/kontakt" }}
    backgroundVariant="dark"
  />

  <ContentParagraph
    kicker="Das Prinzip"
    headline="Weniger Hürden für Käufer – mehr Ergebnis für Sie."
    text="Käufer sind in Deutschland mit hohen Kaufnebenkosten konfrontiert: Grunderwerbsteuer, Notar, Grundbuch – und im klassischen Modell zusätzlich eine Maklerprovision von rund 3,57 %. Diese Nebenkosten müssen in der Regel aus Eigenkapital gezahlt werden, weil Banken sie meist nicht oder nur zu schlechteren Konditionen finanzieren.<br><br>Bei einem Haus mit rund 450.000 € Kaufpreis entstehen so schnell zusätzliche Kosten im fünfstelligen Bereich allein durch die Maklerprovision. Viele potenzielle Käufer fallen dadurch komplett raus oder sind deutlich eingeschränkt.<br><br>Unser Modell setzt genau hier an: 2,975 % Provision auf Verkäuferseite – keine Käuferprovision. Damit sinkt die Einstiegshürde erheblich, Käufer benötigen weniger Eigenkapital und Finanzierungen werden einfacher. Der Kreis der real kaufkräftigen Interessenten wird größer – und das stärkt Ihre Position als Verkäufer."
    backgroundVariant="light"
  />

  <FeaturesGrid
    headline="Was der Wegfall der Käuferprovision konkret bewirkt"
    features={[
      { icon: "users", title: "Mehr qualifizierte Käufer", text: "Niedrigere Kaufnebenkosten bedeuten, dass mehr Interessenten die Finanzierungsanforderungen der Banken erfüllen." },
      { icon: "chart-bar", title: "Höhere Nachfrage", text: "Ein größerer Kreis finanzierungsfähiger Käufer erhöht die aktive Nachfrage nach Ihrer Immobilie messbar." },
      { icon: "lightning", title: "Mehr Wettbewerb", text: "Mehr Interessenten führen zu mehr Wettbewerb unter den Käufern – das wirkt direkt auf den erzielbaren Preis." },
      { icon: "euro", title: "Besserer Verkaufspreis", text: "Wettbewerb unter Käufern ist der effektivste Mechanismus für einen höheren Verkaufspreis." },
      { icon: "clock", title: "Schnellerer Verkauf", text: "Weniger Finanzierungen scheitern an Nebenkosten. Das beschleunigt den Abschluss und erhöht die Planungssicherheit." },
      { icon: "shield-check", title: "Keine Interessenkonflikte", text: "Da wir ausschließlich für Sie tätig sind, wird jede Entscheidung konsequent in Ihrem Sinne getroffen." }
    ]}
    columns={3}
    variant="cards"
    backgroundVariant="light"
  />

  <ContentParagraph
    kicker="Regional gedacht"
    headline="Mehr Chancen für Käufer – mehr Ergebnis für Verkäufer."
    text="Gerade in Preetz, Kiel und Umgebung gibt es viele junge Familien, die Eigentum bilden möchten, aber oft an genau diesen Nebenkosten scheitern. Unser Ansatz gibt diesen Menschen wieder eine realistische Chance, überhaupt Eigentum zu erwerben – und erweitert gleichzeitig den Kreis der Interessenten für Ihre Immobilie.<br><br>Wenn ein Käufer nicht zusätzlich mehrere zehntausend Euro Maklerkosten aus Eigenkapital aufbringen muss, verbessert das häufig seine Finanzierungsspielräume. Käufer haben mehr Spielraum und können sich eher für eine Immobilie entscheiden – oder auch einen leicht höheren Kaufpreis darstellen.<br><br>Das ist kein sozialer Ansatz im klassischen Sinne, sondern eine logischere und effizientere Struktur für den Markt. Unser Modell schafft Vorteile für alle Beteiligten – Verkäufer, Käufer und den gesamten Verkaufsprozess."
    backgroundVariant="light"
  />

  <ContentQuote
    quote="Wenn Immobilien für mehr Menschen erreichbar werden, profitieren am Ende alle Seiten."
    name="Marcel Ziebell"
    role="Gründer, Immobilienkontor am Kirchsee"
    image={{ src: portraitImg.src, alt: "Marcel Ziebell, Gründer Immobilienkontor am Kirchsee" }}
    backgroundVariant="dark"
  />

  <ContentParagraph
    kicker="Warum dieses Modell funktioniert"
    headline="Effizient, fokussiert, ohne unnötige Strukturen."
    text="Wir verzichten bewusst auf einen Teil der branchenüblichen Provision, weil wir sehr effizient arbeiten. Keine unnötigen Strukturen, keine Nebentätigkeiten wie Vermietung oder Verwaltung.<br><br>Wir konzentrieren uns ausschließlich auf unsere Kernkompetenz: das Vermarkten von Immobilien aller Art.<br><br>Diese Fokussierung ermöglicht es uns, ein Vergütungsmodell anzubieten, das für Verkäufer wirtschaftlich sinnvoller ist – ohne Abstriche bei der Qualität der Beratung oder Vermarktung."
    backgroundVariant="dark"
  />

  <CTABanner
    headline="Erfahren Sie, was unser Ansatz für Ihre Immobilie bedeutet."
    subline="Unverbindliches Erstgespräch – kostenlos und direkt mit Marcel Ziebell."
    primaryCta={{ label: "Jetzt anfragen", href: "/kontakt" }}
    backgroundVariant="light"
  />

  <FooterStandard
    logo={{ src: "/logo.svg", alt: "Immobilienkontor am Kirchsee Logo", height: 80 }}
    description="Konsequent auf Ihrer Seite."
    columns={[
      {
        headline: "Leistungen",
        links: [
          { label: "Immobilien verkaufen", href: "/leistungen" },
          { label: "Ihr wirtschaftlicher Vorteil", href: "/ihr-vorteil" },
          { label: "Tippgeber-Programm", href: "/tippgeber" }
        ]
      },
      {
        headline: "Unternehmen",
        links: [
          { label: "Über uns", href: "/ueber-uns" },
          { label: "Kontakt", href: "/kontakt" }
        ]
      }
    ]}
    contact={{ address: "Lange Brückstraße 28, 24211 Preetz" }}
    legalLinks={[
      { label: "Impressum", href: "/impressum" },
      { label: "Datenschutz", href: "/datenschutz" }
    ]}
    copyright="© 2026 Immobilienkontor am Kirchsee. Alle Rechte vorbehalten."
  />
</BaseLayout>
