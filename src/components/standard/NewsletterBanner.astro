---
interface Props {
  headline: string;
  subline?: string;
  placeholder?: string;
  buttonLabel?: string;
  backgroundVariant?: 'light' | 'dark' | 'primary';
  action?: string;
}

const {
  headline,
  subline,
  placeholder = 'Ihre E-Mail-Adresse',
  buttonLabel = 'Anmelden',
  backgroundVariant = 'light',
  action = '#',
} = Astro.props;

const bgClass = {
  light: 'bg-[var(--color-surface)]',
  dark: 'bg-[var(--color-text)] text-[var(--color-bg)]',
  primary: 'bg-[var(--color-primary)]',
}[backgroundVariant];

const headlineClass = {
  light: 'text-[var(--color-text)]',
  dark: 'text-[var(--color-bg)]',
  primary: 'text-[var(--color-text-inverse)]',
}[backgroundVariant];

const sublineClass = {
  light: 'text-[var(--color-text-muted)]',
  dark: 'text-[var(--color-bg)]/70',
  primary: 'text-[var(--color-text-inverse)]/75',
}[backgroundVariant];

const inputClass = {
  light: 'bg-white border-[var(--color-border)] text-[var(--color-text)] placeholder:text-[var(--color-text-muted)]',
  dark: 'bg-white/10 border-white/20 text-white placeholder:text-white/50',
  primary: 'bg-white/15 border-white/30 text-white placeholder:text-white/60',
}[backgroundVariant];

const btnClass = {
  light: 'bg-[var(--color-primary)] text-[var(--color-text-inverse)] hover:opacity-90',
  dark: 'bg-white text-[var(--color-text)] hover:bg-white/90',
  primary: 'bg-white text-[var(--color-primary)] hover:bg-white/90',
}[backgroundVariant];
---

<div class={`animate-on-scroll ${bgClass} py-12 md:py-16`}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="animate-stagger flex flex-col items-center text-center gap-6 md:flex-row md:text-left md:justify-between">
      <div class="animate-item animate-up flex-1">
        <h2 class={`text-xl md:text-2xl font-bold ${headlineClass}`}>{headline}</h2>
        {subline && (
          <p class={`mt-1.5 text-sm ${sublineClass}`}>{subline}</p>
        )}
      </div>

      <form
        action={action}
        method="post"
        class="animate-item animate-up flex flex-col sm:flex-row gap-2 w-full md:w-auto"
        onsubmit="return false;"
      >
        <label class="sr-only" for="newsletter-email">E-Mail-Adresse</label>
        <input
          id="newsletter-email"
          type="email"
          name="email"
          required
          placeholder={placeholder}
          class={`flex-1 min-w-0 w-full sm:w-64 px-4 py-2.5 rounded border text-sm outline-none focus:ring-2 focus:ring-[var(--color-primary)] focus:border-[var(--color-primary)] transition ${inputClass}`}
        />
        <button
          type="submit"
          class={`px-6 py-2.5 rounded text-sm font-semibold whitespace-nowrap transition ${btnClass}`}
        >
          {buttonLabel}
        </button>
      </form>
    </div>

    <p class={`mt-4 text-center text-xs ${sublineClass} md:text-right`}>
      Kein Spam. Jederzeit abmeldbar.
    </p>

  </div>
</div>
