---
interface Testimonial {
  quote: string;
  name: string;
  role: string;
  image?: string;
  rating?: 1 | 2 | 3 | 4 | 5;
}

interface Props {
  headline?: string;
  subline?: string;
  testimonials: Testimonial[];
  columns?: 2 | 3;
}

const {
  headline,
  subline,
  testimonials,
  columns = 3,
} = Astro.props;

const gridClass = columns === 2
  ? 'grid-cols-1 sm:grid-cols-2'
  : 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-3';
---

<section class="animate-on-scroll py-16 md:py-24 bg-[var(--color-bg)]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    {(headline || subline) && (
      <div class="text-center mb-12 md:mb-16">
        {headline && (
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-[var(--color-text)] mb-4">
            {headline}
          </h2>
        )}
        {subline && (
          <p class="text-lg text-[var(--color-text-muted)] max-w-2xl mx-auto">
            {subline}
          </p>
        )}
      </div>
    )}

    <div class={`animate-stagger grid ${gridClass} gap-6`}>
      {testimonials.map((t) => (
        <article class="animate-item animate-up relative flex flex-col gap-5 p-7 bg-[var(--color-surface)] border border-[var(--color-border)] rounded-sm shadow-sm">

          {/* Dekoratives Anführungszeichen */}
          <svg
            class="absolute top-6 right-7 w-10 h-10 text-[var(--color-primary)] opacity-10"
            viewBox="0 0 32 32"
            fill="currentColor"
            aria-hidden="true"
          >
            <path d="M10 8C5.6 8 2 11.6 2 16s3.6 8 8 8c.7 0 1.3-.1 1.9-.2C10.7 25.9 9.1 28 6 28H4v4h2c6.1 0 10-4.5 10-10V12c0-2.2-1.8-4-4-4h-2zm16 0c-4.4 0-8 3.6-8 8s3.6 8 8 8c.7 0 1.3-.1 1.9-.2-.2 2.1-1.8 4.2-4.9 4.2H22v4h2c6.1 0 10-4.5 10-10V12c0-2.2-1.8-4-4-4h-2z"/>
          </svg>

          {/* Sterne (optional) */}
          {t.rating && (
            <div class="flex gap-0.5" aria-label={`${t.rating} von 5 Sternen`}>
              {[1, 2, 3, 4, 5].map((star) => (
                <svg
                  class={`w-4 h-4 ${star <= t.rating! ? 'text-[var(--color-secondary)]' : 'text-[var(--color-border)]'}`}
                  fill="currentColor"
                  viewBox="0 0 20 20"
                  aria-hidden="true"
                >
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              ))}
            </div>
          )}

          {/* Zitat */}
          <blockquote class="flex-1 text-base leading-relaxed text-[var(--color-text-muted)]">
            „{t.quote}"
          </blockquote>

          {/* Autor */}
          <footer class="flex items-center gap-3 pt-4 border-t border-[var(--color-border)]">
            {t.image ? (
              <img
                src={t.image}
                alt={t.name}
                class="w-12 h-12 rounded-full object-cover flex-shrink-0"
              />
            ) : (
              <div class="w-12 h-12 rounded-full bg-[var(--color-primary)] opacity-20 flex items-center justify-center flex-shrink-0">
                <span class="text-lg font-bold text-[var(--color-primary)] opacity-100">
                  {t.name.charAt(0)}
                </span>
              </div>
            )}
            <div>
              <div class="text-sm font-semibold text-[var(--color-text)]">{t.name}</div>
              <div class="text-xs text-[var(--color-text-muted)]">{t.role}</div>
            </div>
          </footer>

        </article>
      ))}
    </div>

  </div>
</section>
