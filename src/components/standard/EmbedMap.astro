---
interface Props {
  embedUrl: string;
  height?: 'sm' | 'md' | 'lg';
  headline?: string;
  subline?: string;
  borderRadius?: boolean;
  bordered?: boolean;
}

const {
  embedUrl,
  height = 'md',
  headline,
  subline,
  borderRadius = true,
  bordered = false,
} = Astro.props;

const heightPx = { sm: '300px', md: '450px', lg: '600px' }[height];
const mapId = `embed-map-${Math.random().toString(36).slice(2, 8)}`;
---

<section class="animate-on-scroll py-0">
  {(headline || subline) && (
    <div class="text-center py-12 md:py-16 px-4">
      {headline && (
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-[var(--color-text)] mb-4">
          {headline}
        </h2>
      )}
      {subline && (
        <p class="text-lg text-[var(--color-text-muted)] max-w-2xl mx-auto">{subline}</p>
      )}
    </div>
  )}

  <div
    id={mapId}
    class={`overflow-hidden ${borderRadius ? 'rounded-xl' : ''} ${bordered ? 'border border-[var(--color-border)]' : ''}`}
    style={`height: ${heightPx};`}
    data-map-url={embedUrl}
    data-map-title={headline ?? 'Karte'}
  >
    {/* Placeholder (shown when consent missing) */}
    <div data-map-placeholder style="display:none; width:100%; height:100%; background:var(--color-surface); border:1px solid var(--color-border); border-radius:0.75rem; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:0.75rem; text-align:center; padding:1.5rem;">
      <svg style="width:2rem; height:2rem; color:var(--color-text-muted);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
      </svg>
      <p style="margin:0; font-size:0.875rem; color:var(--color-text-muted);">Google Maps ist deaktiviert.</p>
      <button data-map-activate type="button" style="padding:0.5rem 1.25rem; border-radius:0.375rem; font-size:0.875rem; font-weight:600; border:1.5px solid var(--color-primary); background:var(--color-primary); color:var(--color-text-inverse); cursor:pointer;">
        Google Maps aktivieren
      </button>
    </div>

    {/* iframe (hidden until consent) */}
    <iframe
      data-map-iframe
      data-src={embedUrl}
      width="100%"
      height="100%"
      style="border:0; display:none;"
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      title={headline ?? 'Karte'}
      allowfullscreen
    />
    {/* Consent status line */}
    <div data-map-status style="display:none; text-align:center; padding:0.375rem 0; font-size:0.75rem; color:var(--color-text-muted);">
      Google Maps aktiv · <button data-map-revoke type="button" style="background:none; border:none; color:var(--color-primary); cursor:pointer; font-size:0.75rem; text-decoration:underline; padding:0;">Widerrufen</button>
    </div>
  </div>
</section>

<script define:vars={{ mapId }}>
  (function () {
    const container = document.getElementById(mapId);
    if (!container) return;

    const iframe = container.querySelector('[data-map-iframe]');
    const placeholder = container.querySelector('[data-map-placeholder]');
    const status = container.querySelector('[data-map-status]');
    const activateBtn = container.querySelector('[data-map-activate]');
    const revokeBtn = container.querySelector('[data-map-revoke]');
    const mapUrl = container.dataset.mapUrl;

    function update() {
      const consent = localStorage.getItem('cookie-consent');
      if (consent === 'all') {
        iframe.src = mapUrl;
        iframe.style.display = 'block';
        placeholder.style.display = 'none';
        status.style.display = 'block';
      } else {
        iframe.removeAttribute('src');
        iframe.style.display = 'none';
        placeholder.style.display = 'flex';
        status.style.display = 'none';
      }
    }

    activateBtn?.addEventListener('click', function () {
      localStorage.setItem('cookie-consent', 'all');
      window.dispatchEvent(new CustomEvent('cookie-consent-changed'));
      update();
    });

    revokeBtn?.addEventListener('click', function () {
      localStorage.setItem('cookie-consent', 'necessary');
      window.dispatchEvent(new CustomEvent('cookie-consent-changed'));
      update();
    });

    window.addEventListener('cookie-consent-changed', update);
    update();
  })();
</script>
