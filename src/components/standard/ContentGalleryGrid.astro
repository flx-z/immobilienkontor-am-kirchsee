---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface GalleryImage {
  src: ImageMetadata | string;
  alt: string;
}

interface Props {
  headline?: string;
  subline?: string;
  images: GalleryImage[];
  columns?: 3 | 4;
  lightbox?: boolean;
}

const {
  headline,
  subline,
  images,
  columns = 3,
  lightbox = true,
} = Astro.props;

const colClass = columns === 4
  ? 'grid-cols-2 md:grid-cols-4'
  : 'grid-cols-2 md:grid-cols-3';

const uid = `gallery-${Math.random().toString(36).slice(2, 8)}`;
---

<section class="animate-on-scroll py-16 md:py-24 bg-[var(--color-bg)]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    {(headline || subline) && (
      <div class="text-center mb-10 md:mb-14">
        {headline && (
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-[var(--color-text)] mb-4">
            {headline}
          </h2>
        )}
        {subline && (
          <p class="text-lg text-[var(--color-text-muted)] max-w-2xl mx-auto">{subline}</p>
        )}
      </div>
    )}

    <div id={uid} class={`animate-stagger grid ${colClass} gap-2 md:gap-3`}>
      {images.map((img, i) => (
        <button
          class="animate-item animate-zoom group relative aspect-square overflow-hidden rounded-sm focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-primary)]"
          data-lightbox-trigger={lightbox ? '' : undefined}
          data-index={lightbox ? i : undefined}
          aria-label={lightbox ? `Bild vergrößern: ${img.alt}` : undefined}
          type="button"
        >
          {typeof img.src === 'string' ? (
            img.src && <img src={img.src} alt={img.alt || ''} loading="lazy" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" />
          ) : (
            <Image src={img.src} alt={img.alt || ''} widths={[300, 500, 800]} formats={['webp', 'avif']} loading="lazy" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" />
          )}
          {lightbox && (
            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/30 transition-colors duration-300 flex items-center justify-center">
              <svg class="w-8 h-8 text-white opacity-0 group-hover:opacity-100 transition-opacity duration-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0zm-2-2h-4m2-2v4"/>
              </svg>
            </div>
          )}
        </button>
      ))}
    </div>

  </div>
</section>

{lightbox && (
  <>
    {/* Lightbox Overlay */}
    <div
      id={`${uid}-lightbox`}
      class="fixed inset-0 z-50 hidden bg-black/90 flex items-center justify-center"
      aria-modal="true"
      role="dialog"
      aria-label="Bildergalerie"
    >
      {/* Schließen */}
      <button
        id={`${uid}-close`}
        class="absolute top-4 right-4 w-10 h-10 flex items-center justify-center text-white hover:text-[var(--color-primary)] transition-colors"
        aria-label="Schließen"
        type="button"
      >
        <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>

      {/* Vorheriges */}
      <button
        id={`${uid}-prev`}
        class="absolute left-3 md:left-6 w-12 h-12 flex items-center justify-center text-white hover:text-[var(--color-primary)] transition-colors"
        aria-label="Vorheriges Bild"
        type="button"
      >
        <svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
        </svg>
      </button>

      {/* Bild */}
      <img
        id={`${uid}-img`}
        src=""
        alt=""
        class="max-h-[90vh] max-w-[90vw] object-contain rounded-sm shadow-2xl"
      />

      {/* Nächstes */}
      <button
        id={`${uid}-next`}
        class="absolute right-3 md:right-6 w-12 h-12 flex items-center justify-center text-white hover:text-[var(--color-primary)] transition-colors"
        aria-label="Nächstes Bild"
        type="button"
      >
        <svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
      </button>

      {/* Counter */}
      <p id={`${uid}-counter`} class="absolute bottom-4 left-1/2 -translate-x-1/2 text-white/60 text-sm tabular-nums"></p>
    </div>
  </>
)}

<script define:vars={{ uid, lightbox, images: images.map(img => ({ src: typeof img.src === 'string' ? img.src : img.src.src, alt: img.alt })) }}>
  if (!lightbox) return;

  const gallery = document.getElementById(uid);
  const lightboxEl = document.getElementById(`${uid}-lightbox`);
  const imgEl = document.getElementById(`${uid}-img`);
  const counter = document.getElementById(`${uid}-counter`);
  if (!gallery || !lightboxEl || !imgEl) return;

  let current = 0;

  function open(index) {
    current = ((index % images.length) + images.length) % images.length;
    imgEl.src = images[current].src;
    imgEl.alt = images[current].alt;
    if (counter) counter.textContent = `${current + 1} / ${images.length}`;
    lightboxEl.classList.remove('hidden');
    lightboxEl.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }

  function close() {
    lightboxEl.classList.add('hidden');
    lightboxEl.classList.remove('flex');
    document.body.style.overflow = '';
  }

  gallery.querySelectorAll('[data-lightbox-trigger]').forEach((btn) => {
    btn.addEventListener('click', () => open(parseInt(btn.dataset.index ?? '0')));
  });

  document.getElementById(`${uid}-close`)?.addEventListener('click', close);
  document.getElementById(`${uid}-prev`)?.addEventListener('click', () => open(current - 1));
  document.getElementById(`${uid}-next`)?.addEventListener('click', () => open(current + 1));

  lightboxEl.addEventListener('click', (e) => { if (e.target === lightboxEl) close(); });

  document.addEventListener('keydown', (e) => {
    if (lightboxEl.classList.contains('hidden')) return;
    if (e.key === 'Escape') close();
    if (e.key === 'ArrowLeft') open(current - 1);
    if (e.key === 'ArrowRight') open(current + 1);
  });
</script>
