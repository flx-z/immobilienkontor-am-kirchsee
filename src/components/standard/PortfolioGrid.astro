---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Project {
  image: { src: ImageMetadata | string; alt: string };
  title: string;
  category: string;
  href?: string;
}

interface Props {
  headline?: string;
  subline?: string;
  projects: Project[];
  columns?: 2 | 3;
  filter?: boolean;
}

const { headline, subline, projects, columns = 3, filter = false } = Astro.props;

const colClass = columns === 2
  ? 'grid-cols-2 md:grid-cols-2'
  : 'grid-cols-2 md:grid-cols-3';

// Einzigartige Kategorien
const categories = filter ? ['Alle', ...new Set(projects.map((p) => p.category))] : [];
const uid = `portfolio-${Math.random().toString(36).slice(2, 8)}`;
---

<section class="animate-on-scroll py-16 md:py-24 bg-[var(--color-bg)]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    {(headline || subline) && (
      <div class="text-center mb-10 md:mb-14">
        {headline && (
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-[var(--color-text)] mb-4">
            {headline}
          </h2>
        )}
        {subline && (
          <p class="text-lg text-[var(--color-text-muted)] max-w-2xl mx-auto">{subline}</p>
        )}
      </div>
    )}

    {/* Filterleiste */}
    {filter && (
      <div id={`${uid}-filters`} class="flex flex-wrap justify-center gap-2 mb-8 md:mb-12">
        {categories.map((cat, i) => (
          <button
            data-filter={cat}
            class={`px-4 py-2 text-sm font-medium rounded-full border transition-all duration-150 ${i === 0 ? 'bg-[var(--color-primary)] text-[var(--color-text-inverse)] border-[var(--color-primary)]' : 'border-[var(--color-border)] text-[var(--color-text-muted)] hover:border-[var(--color-primary)] hover:text-[var(--color-primary)]'}`}
            type="button"
          >
            {cat}
          </button>
        ))}
      </div>
    )}

    {/* Grid */}
    <div id={`${uid}-grid`} class={`animate-stagger grid ${colClass} gap-2 md:gap-4`}>
      {projects.map((project) => {
        const Inner = (
          <div class="group relative aspect-[4/3] overflow-hidden rounded-sm bg-[var(--color-surface)]" data-category={project.category}>
            {typeof project.image.src === 'string' ? (
              project.image.src && <img src={project.image.src} alt={project.image.alt || ''} loading="lazy" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
            ) : (
              <Image src={project.image.src} alt={project.image.alt || ''} widths={[300, 500, 800]} formats={['webp', 'avif']} loading="lazy" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
            )}

            {/* Gradient – beim Hover etwas dunkler */}
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/10 to-transparent group-hover:from-black/80 group-hover:via-black/30 transition-all duration-300" />

            {/* Text – bleibt immer unten links */}
            <div class="absolute inset-x-0 bottom-0 p-4 flex flex-col pointer-events-none">
              <p class="text-[10px] font-semibold tracking-widest uppercase text-white/70 mb-0.5">
                {project.category}
              </p>
              <h3 class="text-sm font-bold text-white leading-tight drop-shadow">
                {project.title}
              </h3>
              {project.href && (
                <span class="mt-1.5 text-xs font-medium text-white/0 group-hover:text-white/80 transition-colors duration-300 underline underline-offset-2">
                  Projekt ansehen →
                </span>
              )}
            </div>
          </div>
        );

        return project.href
          ? <a href={project.href} class="animate-item animate-up block" aria-label={project.title}>{Inner}</a>
          : <div class="animate-item animate-up">{Inner}</div>;
      })}
    </div>

  </div>
</section>

{filter && (
  <script define:vars={{ uid, projects }}>
    const filtersEl = document.getElementById(`${uid}-filters`);
    const gridEl = document.getElementById(`${uid}-grid`);
    if (!filtersEl || !gridEl) return;

    let active = 'Alle';
    const items = gridEl.querySelectorAll('[data-category]');

    filtersEl.querySelectorAll('[data-filter]').forEach((btn) => {
      btn.addEventListener('click', () => {
        active = btn.dataset.filter;

        // Button-Stile
        filtersEl.querySelectorAll('[data-filter]').forEach((b) => {
          const isActive = b.dataset.filter === active;
          b.className = `px-4 py-2 text-sm font-medium rounded-full border transition-all duration-150 ${
            isActive
              ? 'bg-[var(--color-primary)] text-[var(--color-text-inverse)] border-[var(--color-primary)]'
              : 'border-[var(--color-border)] text-[var(--color-text-muted)] hover:border-[var(--color-primary)] hover:text-[var(--color-primary)]'
          }`;
        });

        // Items ein-/ausblenden
        items.forEach((item) => {
          const parent = item.closest('a, div');
          if (!parent) return;
          const match = active === 'Alle' || item.dataset.category === active;
          parent.style.display = match ? '' : 'none';
        });
      });
    });
  </script>
)}
