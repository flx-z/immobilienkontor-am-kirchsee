---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface GalleryImage {
  src: ImageMetadata | string;
  alt: string;
}

interface Props {
  headline?: string;
  subline?: string;
  images: GalleryImage[];
  autoplay?: boolean;
  autoplayInterval?: number;
}

const {
  headline,
  subline,
  images,
  autoplay = false,
  autoplayInterval = 4000,
} = Astro.props;

const uid = `slider-${Math.random().toString(36).slice(2, 8)}`;
---

<section class="animate-on-scroll py-16 md:py-24 bg-[var(--color-bg)]">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

    {(headline || subline) && (
      <div class="text-center mb-10 md:mb-14">
        {headline && (
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-[var(--color-text)] mb-4">
            {headline}
          </h2>
        )}
        {subline && (
          <p class="text-lg text-[var(--color-text-muted)] max-w-2xl mx-auto">{subline}</p>
        )}
      </div>
    )}

    <div id={uid} class="relative select-none">

      {/* Slide-Track */}
      <div class="relative w-full aspect-video overflow-hidden rounded-md shadow-lg bg-[var(--color-surface)]">
        {images.map((img, i) => (
          <div
            class={`absolute inset-0 transition-opacity duration-500 ${i === 0 ? 'opacity-100 z-10' : 'opacity-0 z-0'}`}
            data-slide={i}
          >
            {typeof img.src === 'string' ? (
              img.src && <img src={img.src} alt={img.alt || ''} loading={i === 0 ? 'eager' : 'lazy'} class="w-full h-full object-cover" />
            ) : (
              <Image src={img.src} alt={img.alt || ''} widths={[600, 900, 1200]} formats={['webp', 'avif']} loading={i === 0 ? 'eager' : 'lazy'} class="w-full h-full object-cover" />
            )}
          </div>
        ))}
      </div>

      {/* Pfeil links */}
      <button
        id={`${uid}-prev`}
        class="absolute left-3 top-1/2 -translate-y-1/2 z-20 w-10 h-10 md:w-12 md:h-12 rounded-full bg-white/80 hover:bg-white shadow flex items-center justify-center text-[var(--color-primary)] transition-all duration-150 hover:scale-110"
        aria-label="Vorheriges Bild"
        type="button"
      >
        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
        </svg>
      </button>

      {/* Pfeil rechts */}
      <button
        id={`${uid}-next`}
        class="absolute right-3 top-1/2 -translate-y-1/2 z-20 w-10 h-10 md:w-12 md:h-12 rounded-full bg-white/80 hover:bg-white shadow flex items-center justify-center text-[var(--color-primary)] transition-all duration-150 hover:scale-110"
        aria-label="Nächstes Bild"
        type="button"
      >
        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
      </button>

      {/* Dot-Navigation */}
      <div class="flex justify-center gap-2 mt-5" role="tablist" aria-label="Bildauswahl">
        {images.map((_, i) => (
          <button
            class={`w-2.5 h-2.5 rounded-full transition-all duration-200 ${i === 0 ? 'bg-[var(--color-primary)] scale-125' : 'bg-[var(--color-border)] hover:bg-[var(--color-text-muted)]'}`}
            data-dot={i}
            aria-label={`Bild ${i + 1}`}
            role="tab"
            type="button"
          ></button>
        ))}
      </div>

    </div>

  </div>
</section>

<script define:vars={{ uid, images, autoplay, autoplayInterval }}>
  const container = document.getElementById(uid);
  if (!container) return;

  const slides = container.querySelectorAll('[data-slide]');
  const dots = container.querySelectorAll('[data-dot]');
  let current = 0;
  let timer = null;

  function goTo(i) {
    slides[current].classList.replace('opacity-100', 'opacity-0');
    slides[current].classList.replace('z-10', 'z-0');
    dots[current].classList.remove('bg-[var(--color-primary)]', 'scale-125');
    dots[current].classList.add('bg-[var(--color-border)]');

    current = ((i % slides.length) + slides.length) % slides.length;

    slides[current].classList.replace('opacity-0', 'opacity-100');
    slides[current].classList.replace('z-0', 'z-10');
    dots[current].classList.add('bg-[var(--color-primary)]', 'scale-125');
    dots[current].classList.remove('bg-[var(--color-border)]');
  }

  document.getElementById(`${uid}-prev`)?.addEventListener('click', () => { goTo(current - 1); resetTimer(); });
  document.getElementById(`${uid}-next`)?.addEventListener('click', () => { goTo(current + 1); resetTimer(); });
  dots.forEach((dot) => dot.addEventListener('click', () => { goTo(parseInt(dot.dataset.dot)); resetTimer(); }));

  // Touch / Swipe
  let touchX = 0;
  const track = container.querySelector('[data-slide]')?.parentElement;
  track?.addEventListener('touchstart', (e) => { touchX = e.touches[0].clientX; }, { passive: true });
  track?.addEventListener('touchend', (e) => {
    const diff = touchX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 40) { goTo(diff > 0 ? current + 1 : current - 1); resetTimer(); }
  });

  // Autoplay
  function startTimer() {
    if (!autoplay) return;
    timer = setInterval(() => goTo(current + 1), autoplayInterval);
  }
  function resetTimer() {
    clearInterval(timer);
    startTimer();
  }

  // Pause on hover
  if (autoplay) {
    container.addEventListener('mouseenter', () => clearInterval(timer));
    container.addEventListener('mouseleave', startTimer);
    startTimer();
  }
</script>
