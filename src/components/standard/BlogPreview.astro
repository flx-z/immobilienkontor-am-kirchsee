---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Post {
  image: { src: ImageMetadata | string; alt: string };
  title: string;
  date: string;
  teaser: string;
  href: string;
  category?: string;
}

interface Props {
  headline?: string;
  subline?: string;
  posts: Post[];
  cta?: { label: string; href: string };
}

const { headline, subline, posts, cta } = Astro.props;
---

<section class="animate-on-scroll py-16 md:py-24 bg-[var(--color-bg)]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    {(headline || subline) && (
      <div class="text-center mb-10 md:mb-14">
        {headline && (
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-[var(--color-text)] mb-4">
            {headline}
          </h2>
        )}
        {subline && (
          <p class="text-lg text-[var(--color-text-muted)] max-w-2xl mx-auto">{subline}</p>
        )}
      </div>
    )}

    <div class="animate-stagger grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
      {posts.map((post) => (
        <a
          href={post.href}
          class="animate-item animate-up group flex flex-col rounded-sm overflow-hidden border border-[var(--color-border)] bg-[var(--color-surface)] hover:-translate-y-1.5 hover:shadow-xl transition-all duration-300"
        >
          {/* Thumbnail 16:9 */}
          <div class="aspect-video overflow-hidden flex-shrink-0">
            {typeof post.image.src === 'string' ? (
              post.image.src && <img src={post.image.src} alt={post.image.alt || ''} loading="lazy" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
            ) : (
              <Image src={post.image.src} alt={post.image.alt || ''} widths={[300, 500, 800]} formats={['webp', 'avif']} loading="lazy" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
            )}
          </div>

          {/* Content */}
          <div class="flex flex-col flex-1 p-6 gap-3">
            <div class="flex items-center gap-3">
              <time class="text-xs text-[var(--color-text-muted)]">{post.date}</time>
              {post.category && (
                <span class="text-xs font-medium text-[var(--color-primary)] uppercase tracking-wide">{post.category}</span>
              )}
            </div>
            <h3 class="text-base font-semibold text-[var(--color-text)] leading-snug group-hover:text-[var(--color-primary)] transition-colors duration-150 line-clamp-2">
              {post.title}
            </h3>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed line-clamp-3 flex-1">
              {post.teaser}
            </p>
            <span class="text-sm font-medium text-[var(--color-primary)] inline-flex items-center gap-1 mt-1 group-hover:gap-2 transition-all duration-150">
              Weiterlesen
              <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </span>
          </div>
        </a>
      ))}
    </div>

    {cta && (
      <div class="text-center mt-10 md:mt-14">
        <a
          href={cta.href}
          class="inline-flex items-center gap-2 px-8 py-4 text-base font-semibold rounded-sm border-2 border-[var(--color-primary)] text-[var(--color-primary)] hover:bg-[var(--color-primary)] hover:text-[var(--color-text-inverse)] transition-all duration-200"
        >
          {cta.label}
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    )}

  </div>
</section>
