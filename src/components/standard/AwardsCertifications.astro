---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Item {
  src: string | ImageMetadata;
  alt: string;
  label?: string;
}

interface Props {
  headline?: string;
  subline?: string;
  items: Item[];
  columns?: 3 | 4 | 5;
  background?: boolean; // default: true → --color-surface
}

const {
  headline,
  subline,
  items,
  columns = 4,
  background = true,
} = Astro.props;

const colClass: Record<number, string> = {
  3: 'grid-cols-2 sm:grid-cols-3',
  4: 'grid-cols-2 sm:grid-cols-3 lg:grid-cols-4',
  5: 'grid-cols-2 sm:grid-cols-3 lg:grid-cols-5',
};
---

<section class={`animate-on-scroll py-16 md:py-24 ${background ? 'bg-[var(--color-surface)]' : 'bg-[var(--color-bg)]'}`}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    {(headline || subline) && (
      <div class="text-center mb-12 md:mb-16">
        {headline && (
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-[var(--color-text)] mb-4">
            {headline}
          </h2>
        )}
        {subline && (
          <p class="text-lg text-[var(--color-text-muted)] max-w-2xl mx-auto">
            {subline}
          </p>
        )}
      </div>
    )}

    <div class={`animate-stagger grid ${colClass[columns]} gap-8 md:gap-12`}>
      {items.map((item) => (
        <div class="animate-item animate-zoom flex flex-col items-center gap-3 text-center">

          {/* Siegel / Award-Logo – Originalfarben, keine Graustufen */}
          <div class="flex items-center justify-center h-28 w-full">
            {typeof item.src === 'string' ? (
              <img
                src={item.src}
                alt={item.alt || ''}
                draggable="false"
                class="max-h-[120px] w-auto max-w-[140px] object-contain select-none"
              />
            ) : (
              <Image
                src={item.src}
                alt={item.alt || ''}
                draggable="false"
                class="max-h-[120px] w-auto max-w-[140px] object-contain select-none"
              />
            )}
          </div>

          {/* Optionales Label */}
          {item.label && (
            <span class="text-xs font-semibold tracking-widest uppercase text-[var(--color-text-muted)]">
              {item.label}
            </span>
          )}

        </div>
      ))}
    </div>

  </div>
</section>
