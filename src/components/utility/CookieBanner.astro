---
interface Props {
  text: string;
  acceptLabel?: string;
  declineLabel?: string;
  privacyLink: { label: string; href: string };
}

const {
  text,
  acceptLabel = 'Alle akzeptieren',
  declineLabel = 'Nur notwendige',
  privacyLink,
} = Astro.props;

const uid = `cookie-banner-${Math.random().toString(36).slice(2, 8)}`;
---

<div
  id={uid}
  role="dialog"
  aria-label="Cookie-Einstellungen"
  aria-live="polite"
  style="
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 9999;
    background-color: var(--color-surface);
    border-top: 1px solid var(--color-border);
    padding: 1rem 1.5rem;
    display: none;
  "
>
  <div style="
    max-width: 72rem;
    margin: 0 auto;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
  ">
    {/* Text */}
    <p style="
      flex: 1;
      min-width: 200px;
      font-size: 0.875rem;
      color: var(--color-text);
      margin: 0;
      line-height: 1.5;
    ">
      {text}
      {' '}
      <a
        href={privacyLink.href}
        style="color: var(--color-primary); text-decoration: underline;"
      >
        {privacyLink.label}
      </a>
    </p>

    {/* Buttons */}
    <div style="
      display: flex;
      flex-wrap: wrap;
      gap: 0.625rem;
      flex-shrink: 0;
    ">
      <button
        id={`${uid}-decline`}
        type="button"
        style="
          padding: 0.5rem 1.25rem;
          border-radius: 0.375rem;
          font-size: 0.875rem;
          font-weight: 600;
          border: 1.5px solid var(--color-border);
          background: transparent;
          color: var(--color-text);
          cursor: pointer;
          transition: border-color 0.15s, color 0.15s;
          white-space: nowrap;
        "
        onmouseover="this.style.borderColor='var(--color-primary)';this.style.color='var(--color-primary)'"
        onmouseout="this.style.borderColor='var(--color-border)';this.style.color='var(--color-text)'"
      >
        {declineLabel}
      </button>
      <button
        id={`${uid}-accept`}
        type="button"
        style="
          padding: 0.5rem 1.25rem;
          border-radius: 0.375rem;
          font-size: 0.875rem;
          font-weight: 600;
          border: 1.5px solid var(--color-primary);
          background-color: var(--color-primary);
          color: var(--color-text-inverse);
          cursor: pointer;
          transition: opacity 0.15s;
          white-space: nowrap;
        "
        onmouseover="this.style.opacity='0.87'"
        onmouseout="this.style.opacity='1'"
      >
        {acceptLabel}
      </button>
    </div>
  </div>
</div>

<script define:vars={{ uid }}>
  (function () {
    const banner = document.getElementById(uid);
    if (!banner) return;

    const STORAGE_KEY = 'cookie-consent';

    function showBanner() {
      banner.style.display = 'block';
      banner.style.transform = 'translateY(0)';
      banner.style.opacity = '1';
    }

    function dismiss(choice) {
      localStorage.setItem(STORAGE_KEY, choice);
      banner.style.transition = 'transform 0.3s ease, opacity 0.3s ease';
      banner.style.transform = 'translateY(100%)';
      banner.style.opacity = '0';
      setTimeout(() => { banner.style.display = 'none'; }, 320);
      window.dispatchEvent(new CustomEvent('cookie-consent-changed'));
    }

    // Global function to re-show the banner
    window.__showCookieBanner = showBanner;

    // Show on first visit
    if (!localStorage.getItem(STORAGE_KEY)) {
      showBanner();
    }

    document.getElementById(`${uid}-accept`)?.addEventListener('click', () => dismiss('all'));
    document.getElementById(`${uid}-decline`)?.addEventListener('click', () => dismiss('necessary'));
  })();
</script>
