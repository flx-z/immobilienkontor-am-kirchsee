---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Feature {
  title: string;
  text: string;
  image: {
    src: ImageMetadata | string;
    alt: string;
  };
  cta?: {
    label: string;
    href: string;
  };
}

interface Props {
  headline?: string;
  subline?: string;
  features: Feature[];
}

const { headline, subline, features } = Astro.props;
---

<section class="animate-on-scroll py-16 md:py-24 bg-[var(--color-bg)]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    {(headline || subline) && (
      <div class="text-center mb-16 md:mb-20">
        {headline && (
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-[var(--color-text)] mb-4">
            {headline}
          </h2>
        )}
        {subline && (
          <p class="text-lg text-[var(--color-text-muted)] max-w-2xl mx-auto">
            {subline}
          </p>
        )}
      </div>
    )}

    <div class="flex flex-col gap-20 md:gap-28">
      {features.map((feature, i) => {
        const imageLeft = i % 2 === 0;
        return (
          <article class={`flex flex-col ${imageLeft ? 'lg:flex-row' : 'lg:flex-row-reverse'} items-center gap-10 lg:gap-16`}>

            {/* Bild */}
            <div class="w-full lg:w-1/2 flex-shrink-0">
              <div class="relative overflow-hidden rounded-md aspect-[4/3] lg:aspect-[16/10]">
                {typeof feature.image.src === 'string' ? (
                  feature.image.src && <img src={feature.image.src} alt={feature.image.alt || ''} fetchpriority={i === 0 ? 'high' : 'auto'} loading={i === 0 ? 'eager' : 'lazy'} class="absolute inset-0 w-full h-full object-cover" />
                ) : (
                  <Image src={feature.image.src} alt={feature.image.alt || ''} widths={[400, 800, 1200]} formats={['webp', 'avif']} loading={i === 0 ? 'eager' : 'lazy'} class="absolute inset-0 w-full h-full object-cover" />
                )}
              </div>
            </div>

            {/* Text */}
            <div class="w-full lg:w-1/2">
              <h3 class="text-2xl md:text-3xl font-bold tracking-tight text-[var(--color-text)] mb-5">
                {feature.title}
              </h3>
              <p class="text-base md:text-lg leading-relaxed text-[var(--color-text-muted)] mb-8">
                {feature.text}
              </p>

              {feature.cta && (
                <a
                  href={feature.cta.href}
                  class="inline-flex items-center gap-2 text-sm font-semibold text-[var(--color-primary)] hover:text-[var(--color-secondary)] transition-colors duration-150 group"
                >
                  {feature.cta.label}
                  <svg class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                  </svg>
                </a>
              )}
            </div>

          </article>
        );
      })}
    </div>

  </div>
</section>
