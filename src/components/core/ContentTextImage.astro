---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  kicker?: string;
  headline: string;
  text: string;
  cta?: { label: string; href: string };
  image: { src: ImageMetadata | string; alt: string };
  imagePosition?: 'left' | 'right';
  backgroundVariant?: 'light' | 'dark';
}

const {
  kicker,
  headline,
  text,
  cta,
  image,
  imagePosition = 'right',
  backgroundVariant = 'light',
} = Astro.props;

const isDark = backgroundVariant === 'dark';
const imageLeft = imagePosition === 'left';
---

<section class={`animate-on-scroll py-16 md:py-24 ${isDark ? 'bg-[var(--color-primary)]' : 'bg-[var(--color-bg)]'}`}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class={`flex flex-col ${imageLeft ? 'lg:flex-row' : 'lg:flex-row-reverse'} items-center gap-10 lg:gap-16`}>

      {/* Bild */}
      <div class="w-full lg:w-1/2 flex-shrink-0">
        <div class="relative overflow-hidden rounded-md aspect-[4/3]">
          {typeof image.src === 'string' ? (
            image.src && <img src={image.src} alt={image.alt || ''} class="absolute inset-0 w-full h-full object-cover" />
          ) : (
            <Image src={image.src} alt={image.alt || ''} widths={[400, 800, 1200]} formats={['webp', 'avif']} class="absolute inset-0 w-full h-full object-cover" />
          )}
        </div>
      </div>

      {/* Text */}
      <div class="w-full lg:w-1/2">
        {kicker && (
          <p class={`text-sm font-medium tracking-widest uppercase mb-4 ${isDark ? 'text-[var(--color-secondary)]' : 'text-[var(--color-secondary)]'}`}>
            {kicker}
          </p>
        )}
        <h2 class={`text-3xl md:text-4xl font-bold tracking-tight mb-6 leading-tight ${isDark ? 'text-[var(--color-text-inverse)]' : 'text-[var(--color-text)]'}`}>
          {headline}
        </h2>
        <p class={`text-lg leading-relaxed mb-8 ${isDark ? 'text-[var(--color-text-inverse)] opacity-80' : 'text-[var(--color-text-muted)]'}`}>
          {text}
        </p>
        {cta && (
          <a
            href={cta.href}
            class={`inline-flex items-center px-8 py-4 text-base font-semibold rounded-sm transition-all duration-200 hover:-translate-y-0.5 hover:shadow-lg ${
              isDark
                ? 'bg-[var(--color-text-inverse)] text-[var(--color-primary)] hover:brightness-95'
                : 'bg-[var(--color-primary)] text-[var(--color-text-inverse)] hover:brightness-110'
            }`}
          >
            {cta.label}
          </a>
        )}
      </div>

    </div>
  </div>
</section>
