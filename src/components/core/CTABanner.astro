---
interface Props {
  headline: string;
  subline?: string;
  primaryCta: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  backgroundVariant?: 'primary' | 'dark' | 'light';
  layout?: 'centered' | 'split';
}

const {
  headline,
  subline,
  primaryCta,
  secondaryCta,
  backgroundVariant = 'primary',
  layout = 'split',
} = Astro.props;

const bgClass = {
  primary: 'bg-[var(--color-primary)]',
  dark: 'bg-[var(--color-surface)]',
  light: 'bg-[var(--color-bg)] border-t border-b border-[var(--color-border)]',
}[backgroundVariant];

const textClass = {
  primary: 'text-[var(--color-text-inverse)]',
  dark: 'text-[var(--color-text)]',
  light: 'text-[var(--color-text)]',
}[backgroundVariant];

const sublineStyle = backgroundVariant === 'light'
  ? 'color: var(--color-text);'
  : `color: #000000; opacity: 0.8;`;

const primaryBtnClass = {
  primary: 'bg-white text-[var(--color-primary)] hover:bg-white/90',
  dark: 'bg-[var(--color-primary)] text-[var(--color-text-inverse)] hover:opacity-90',
  light: 'bg-[var(--color-primary)] text-[var(--color-text-inverse)] hover:opacity-90',
}[backgroundVariant];

const secondaryBtnClass = {
  primary: 'border border-white/50 text-[var(--color-text-inverse)] hover:bg-white/10',
  dark: 'border border-[var(--color-border)] text-[var(--color-text)] hover:border-[var(--color-primary)]',
  light: 'border border-[var(--color-border)] text-[var(--color-text)] hover:border-[var(--color-primary)]',
}[backgroundVariant];
---

<div class={`animate-on-scroll ${bgClass} py-12 md:py-16`}>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    {layout === 'split' ? (
      <div class="animate-stagger flex flex-col items-center text-center gap-6 md:flex-row md:justify-between md:text-left">
        <div class="animate-item animate-up flex-1">
          <h2 class={`text-2xl md:text-3xl font-bold tracking-tight ${textClass}`}>
            {headline}
          </h2>
          {subline && (
            <p class="mt-2 text-base" style={sublineStyle}>{subline}</p>
          )}
        </div>
        <div class="animate-item animate-up flex flex-col sm:flex-row gap-3 flex-shrink-0">
          <a
            href={primaryCta.href}
            class={`px-6 py-3 rounded font-semibold text-sm transition-all ${primaryBtnClass}`}
          >
            {primaryCta.label}
          </a>
          {secondaryCta && (
            <a
              href={secondaryCta.href}
              class={`px-6 py-3 rounded font-semibold text-sm transition-all ${secondaryBtnClass}`}
            >
              {secondaryCta.label}
            </a>
          )}
        </div>
      </div>
    ) : (
      <div class="animate-stagger text-center">
        <h2 class={`text-2xl md:text-3xl font-bold tracking-tight ${textClass}`}>
          {headline}
        </h2>
        {subline && (
          <p class="mt-3 text-base max-w-xl mx-auto" style={sublineStyle}>{subline}</p>
        )}
        <div class="animate-item animate-up mt-8 flex flex-col sm:flex-row gap-3 justify-center">
          <a
            href={primaryCta.href}
            class={`px-8 py-3 rounded font-semibold text-sm transition-all ${primaryBtnClass}`}
          >
            {primaryCta.label}
          </a>
          {secondaryCta && (
            <a
              href={secondaryCta.href}
              class={`px-8 py-3 rounded font-semibold text-sm transition-all ${secondaryBtnClass}`}
            >
              {secondaryCta.label}
            </a>
          )}
        </div>
      </div>
    )}

  </div>
</div>
