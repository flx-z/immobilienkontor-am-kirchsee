---
interface Props {
  headline?: string;
  subline?: string;
  contactInfo?: {
    address?: string;
    phone?: string;
    email?: string;
    hours?: string;
  };
  mapEmbed?: string;
  formAction?: string;
  backgroundVariant?: 'light' | 'dark';
}

const {
  headline,
  subline,
  contactInfo = {},
  mapEmbed,
  formAction = '#',
  backgroundVariant = 'light',
} = Astro.props;

const isDark = backgroundVariant === 'dark';
---

<section class={`animate-on-scroll py-16 md:py-24 ${isDark ? 'bg-[var(--color-surface)]' : 'bg-[var(--color-bg)]'}`}>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    {(headline || subline) && (
      <div class="text-center mb-12 md:mb-16">
        {headline && (
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-[var(--color-text)] mb-4">
            {headline}
          </h2>
        )}
        {subline && (
          <p class="text-lg text-[var(--color-text-muted)] max-w-2xl mx-auto">{subline}</p>
        )}
      </div>
    )}

    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16">

      {/* Linke Spalte: Kontaktinfos */}
      <div class="flex flex-col gap-6">

        {contactInfo.address && (
          <div class="flex gap-4 items-start">
            <span class="flex-shrink-0 w-9 h-9 rounded-full bg-[var(--color-primary)]/10 flex items-center justify-center text-[var(--color-primary)]">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </span>
            <div>
              <p class="text-xs font-semibold tracking-widest uppercase text-[var(--color-text-muted)] mb-0.5">Adresse</p>
              <p class="text-sm text-[var(--color-text)] whitespace-pre-line">{contactInfo.address}</p>
            </div>
          </div>
        )}

        {contactInfo.phone && (
          <div class="flex gap-4 items-start">
            <span class="flex-shrink-0 w-9 h-9 rounded-full bg-[var(--color-primary)]/10 flex items-center justify-center text-[var(--color-primary)]">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </span>
            <div>
              <p class="text-xs font-semibold tracking-widest uppercase text-[var(--color-text-muted)] mb-0.5">Telefon</p>
              <a href={`tel:${contactInfo.phone.replace(/\s/g, '')}`} class="text-sm text-[var(--color-text)] hover:text-[var(--color-primary)] transition-colors">
                {contactInfo.phone}
              </a>
            </div>
          </div>
        )}

        {contactInfo.email && (
          <div class="flex gap-4 items-start">
            <span class="flex-shrink-0 w-9 h-9 rounded-full bg-[var(--color-primary)]/10 flex items-center justify-center text-[var(--color-primary)]">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </span>
            <div>
              <p class="text-xs font-semibold tracking-widest uppercase text-[var(--color-text-muted)] mb-0.5">E-Mail</p>
              <a href={`mailto:${contactInfo.email}`} class="text-sm text-[var(--color-text)] hover:text-[var(--color-primary)] transition-colors">
                {contactInfo.email}
              </a>
            </div>
          </div>
        )}

        {contactInfo.hours && (
          <div class="flex gap-4 items-start">
            <span class="flex-shrink-0 w-9 h-9 rounded-full bg-[var(--color-primary)]/10 flex items-center justify-center text-[var(--color-primary)]">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </span>
            <div>
              <p class="text-xs font-semibold tracking-widest uppercase text-[var(--color-text-muted)] mb-0.5">Öffnungszeiten</p>
              <p class="text-sm text-[var(--color-text)] whitespace-pre-line">{contactInfo.hours}</p>
            </div>
          </div>
        )}

        {/* Optionale Karte */}
        {mapEmbed && (
          <div id="contact-map" class="mt-2 rounded-xl overflow-hidden border border-[var(--color-border)]" style="height: 200px;" data-map-url={mapEmbed}>
            <div data-map-placeholder style="display:none; width:100%; height:100%; background:var(--color-surface); display:flex; flex-direction:column; align-items:center; justify-content:center; gap:0.5rem; text-align:center; padding:1rem;">
              <p style="margin:0; font-size:0.8125rem; color:var(--color-text-muted);">Google Maps ist deaktiviert.</p>
              <button data-map-activate type="button" style="padding:0.375rem 1rem; border-radius:0.375rem; font-size:0.8125rem; font-weight:600; border:1.5px solid var(--color-primary); background:var(--color-primary); color:var(--color-text-inverse); cursor:pointer;">
                Aktivieren
              </button>
            </div>
            <iframe
              data-map-iframe
              data-src={mapEmbed}
              width="100%"
              height="100%"
              style="border:0; display:none;"
              loading="lazy"
              title="Karte"
              referrerpolicy="no-referrer-when-downgrade"
            />
            <div data-map-status style="display:none; text-align:center; padding:0.25rem 0; font-size:0.6875rem; color:var(--color-text-muted);">
              Maps aktiv · <button data-map-revoke type="button" style="background:none; border:none; color:var(--color-primary); cursor:pointer; font-size:0.6875rem; text-decoration:underline; padding:0;">Widerrufen</button>
            </div>
          </div>
        )}
      </div>

      {/* Rechte Spalte: Formular */}
      <div>
        <form
          action={formAction}
          method="post"
          class="flex flex-col gap-4"
          onsubmit="return false;"
        >
          <div>
            <label for="contact-name" class="block text-xs font-semibold tracking-wide uppercase text-[var(--color-text-muted)] mb-1.5">Name *</label>
            <input
              id="contact-name"
              type="text"
              name="name"
              required
              placeholder="Max Mustermann"
              class="w-full px-4 py-2.5 rounded border border-[var(--color-border)] bg-[var(--color-bg)] text-[var(--color-text)] text-sm placeholder:text-[var(--color-text-muted)] focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)] focus:border-[var(--color-primary)] transition"
            />
          </div>
          <div>
            <label for="contact-email" class="block text-xs font-semibold tracking-wide uppercase text-[var(--color-text-muted)] mb-1.5">E-Mail *</label>
            <input
              id="contact-email"
              type="email"
              name="email"
              required
              placeholder="max@beispiel.de"
              class="w-full px-4 py-2.5 rounded border border-[var(--color-border)] bg-[var(--color-bg)] text-[var(--color-text)] text-sm placeholder:text-[var(--color-text-muted)] focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)] focus:border-[var(--color-primary)] transition"
            />
          </div>
          <div>
            <label for="contact-phone" class="block text-xs font-semibold tracking-wide uppercase text-[var(--color-text-muted)] mb-1.5">Telefon (optional)</label>
            <input
              id="contact-phone"
              type="tel"
              name="phone"
              placeholder="z.B. +49 152 1234567"
              class="w-full px-4 py-2.5 rounded border border-[var(--color-border)] bg-[var(--color-bg)] text-[var(--color-text)] text-sm placeholder:text-[var(--color-text-muted)] focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)] focus:border-[var(--color-primary)] transition"
            />
          </div>
          <div>
            <label for="contact-message" class="block text-xs font-semibold tracking-wide uppercase text-[var(--color-text-muted)] mb-1.5">Nachricht *</label>
            <textarea
              id="contact-message"
              name="message"
              required
              rows={5}
              placeholder="Wie können wir Ihnen helfen?"
              class="w-full px-4 py-2.5 rounded border border-[var(--color-border)] bg-[var(--color-bg)] text-[var(--color-text)] text-sm placeholder:text-[var(--color-text-muted)] focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)] focus:border-[var(--color-primary)] transition resize-y"
            />
          </div>
          <button
            type="submit"
            class="mt-1 w-full py-3 px-6 bg-[var(--color-primary)] text-[var(--color-text-inverse)] font-semibold text-sm rounded hover:opacity-90 transition"
          >
            Nachricht senden
          </button>
          <p class="text-xs text-[var(--color-text-muted)] text-center">
            Mit dem Absenden stimmen Sie unserer <a href="#" class="underline hover:text-[var(--color-primary)]">Datenschutzerklärung</a> zu.
          </p>
        </form>
      </div>

    </div>
  </div>
</section>

<script>
  (function () {
    const container = document.getElementById('contact-map');
    if (!container) return;

    const iframe = container.querySelector('[data-map-iframe]');
    const placeholder = container.querySelector('[data-map-placeholder]');
    const status = container.querySelector('[data-map-status]');
    const activateBtn = container.querySelector('[data-map-activate]');
    const revokeBtn = container.querySelector('[data-map-revoke]');
    const mapUrl = container.dataset.mapUrl;

    function update() {
      const consent = localStorage.getItem('cookie-consent');
      if (consent === 'all') {
        iframe.src = mapUrl;
        iframe.style.display = 'block';
        placeholder.style.display = 'none';
        status.style.display = 'block';
      } else {
        iframe.removeAttribute('src');
        iframe.style.display = 'none';
        placeholder.style.display = 'flex';
        status.style.display = 'none';
      }
    }

    activateBtn?.addEventListener('click', function () {
      localStorage.setItem('cookie-consent', 'all');
      window.dispatchEvent(new CustomEvent('cookie-consent-changed'));
      update();
    });

    revokeBtn?.addEventListener('click', function () {
      localStorage.setItem('cookie-consent', 'necessary');
      window.dispatchEvent(new CustomEvent('cookie-consent-changed'));
      update();
    });

    window.addEventListener('cookie-consent-changed', update);
    update();
  })();
</script>
