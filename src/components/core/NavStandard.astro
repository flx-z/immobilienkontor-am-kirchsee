---
interface NavLink {
  label: string;
  href: string;
  dropdown?: {
    label: string;
    href: string;
  }[];
}

interface Props {
  logo: string;           // Bildpfad (z.B. '/logo.svg') oder Text-Fallback
  logoAlt?: string;       // Alt-Text für Logo-Bild (default: 'Logo')
  logoHeight?: number;    // Logo-Hoehe in px (default: 32)
  links: NavLink[];
  cta: {
    text: string;
    href: string;
  };
  sticky?: boolean;       // default: true
}

const {
  logo,
  logoAlt = 'Logo',
  logoHeight = 32,
  links,
  cta,
  sticky = true,
} = Astro.props;

const isImageLogo = logo.startsWith('/') || logo.startsWith('http');
const currentPath = Astro.url.pathname;
---

<header
  id="nav-header"
  class={`w-full z-50 bg-[var(--color-primary)] border-b border-[var(--color-primary)] transition-shadow duration-300 ${sticky ? 'sticky top-0' : 'relative'}`}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-20">

      {/* Logo */}
      <a href="/" aria-label="Zur Startseite" class="flex-shrink-0 flex items-center">
        {isImageLogo ? (
          <img src={logo} alt={logoAlt} style={`height: ${logoHeight}px`} class="w-auto" />
        ) : (
          <span class="text-lg font-bold text-white tracking-tight">
            {logo}
          </span>
        )}
      </a>

      {/* Desktop Navigation */}
      <nav class="hidden lg:flex items-center gap-1" aria-label="Hauptnavigation">
        {links.map((link) => {
          const isActive = currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href));
          return (
            <div class="relative group">
              <a
                href={link.href}
                aria-current={isActive ? 'page' : undefined}
                class={`inline-flex items-center gap-1 px-4 py-2 text-sm font-medium transition-colors duration-150 rounded-sm ${
                  isActive
                    ? 'text-white font-semibold underline underline-offset-4 decoration-white decoration-2'
                    : 'text-white/70 hover:text-white'
                }`}
              >
                {link.label}
                {link.dropdown && (
                  <svg class="w-3.5 h-3.5 transition-transform duration-200 group-hover:rotate-180 group-focus-within:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                  </svg>
                )}
              </a>

              {/* Dropdown – hover UND focus-within (Keyboard Nav) */}
              {link.dropdown && (
                <div class="absolute top-full left-0 mt-1 w-52 bg-[var(--color-bg)] border border-[var(--color-border)] shadow-lg rounded-sm opacity-0 invisible group-hover:opacity-100 group-hover:visible group-focus-within:opacity-100 group-focus-within:visible transition-all duration-200 translate-y-1 group-hover:translate-y-0 group-focus-within:translate-y-0 z-50">
                  {link.dropdown.map((item) => {
                    const isDropActive = currentPath === item.href;
                    return (
                      <a
                        href={item.href}
                        aria-current={isDropActive ? 'page' : undefined}
                        class={`block px-4 py-3 text-sm transition-colors duration-150 first:rounded-t-sm last:rounded-b-sm ${
                          isDropActive
                            ? 'text-[var(--color-primary)] bg-[var(--color-surface)] font-medium'
                            : 'text-[var(--color-text-muted)] hover:text-[var(--color-text)] hover:bg-[var(--color-surface)]'
                        }`}
                      >
                        {item.label}
                      </a>
                    );
                  })}
                </div>
              )}
            </div>
          );
        })}
      </nav>

      {/* Desktop CTA */}
      <a
        href={cta.href}
        class="hidden lg:inline-flex items-center px-6 py-2.5 text-sm font-semibold bg-white text-[var(--color-primary)] rounded-sm transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md hover:brightness-110"
      >
        {cta.text}
      </a>

      {/* Mobile: Hamburger */}
      <button
        id="nav-hamburger"
        type="button"
        aria-label="Menü öffnen"
        aria-expanded="false"
        aria-controls="nav-mobile-menu"
        class="lg:hidden flex flex-col justify-center items-center w-10 h-10 gap-1.5 rounded-sm text-white"
      >
        <span class="hamburger-bar block w-5 h-0.5 bg-current transition-all duration-300 origin-center"></span>
        <span class="hamburger-bar block w-5 h-0.5 bg-current transition-all duration-300"></span>
        <span class="hamburger-bar block w-5 h-0.5 bg-current transition-all duration-300 origin-center"></span>
      </button>

    </div>
  </div>

  {/* Mobile Menu – absolute overlay, schiebt Content nicht runter */}
  <div
    id="nav-mobile-menu"
    class="lg:hidden hidden absolute left-0 right-0 top-full border-t border-white/20 bg-[var(--color-primary)] shadow-xl z-40"
    role="dialog"
    aria-label="Mobile Navigation"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-4 flex flex-col">

      {links.map((link, i) => {
        const isActive = currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href));
        return (
          <div>

            {link.dropdown ? (
              // Link MIT Dropdown → Text ist Link, Chevron öffnet Akkordeon
              <div class="flex items-center w-full">
                <a
                  href={link.href}
                  aria-current={isActive ? 'page' : undefined}
                  class={`flex-1 px-2 py-3.5 text-base font-medium ${
                    isActive ? 'text-white' : 'text-white/80'
                  }`}
                >
                  {link.label}
                </a>
                <button
                  type="button"
                  data-accordion-trigger
                  data-index={i}
                  aria-label={`Untermenü ${link.label} öffnen`}
                  class="p-3 text-white/70"
                >
                  <svg
                    data-chevron
                    class="w-4 h-4 transition-transform duration-200"
                    fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                  </svg>
                </button>
              </div>
            ) : (
              // Einfacher Link ohne Dropdown
              <a
                href={link.href}
                aria-current={isActive ? 'page' : undefined}
                class={`flex items-center w-full px-2 py-3.5 text-base font-medium ${
                  isActive ? 'text-white' : 'text-white/80'
                }`}
              >
                {link.label}
              </a>
            )}

            {/* Akkordeon-Inhalt – standardmäßig hidden */}
            {link.dropdown && (
              <div data-accordion-content data-index={i} class="hidden pl-4 pb-2 flex flex-col">
                {link.dropdown.map((item) => {
                  const isDropActive = currentPath === item.href;
                  return (
                    <a
                      href={item.href}
                      aria-current={isDropActive ? 'page' : undefined}
                      class={`block py-2.5 text-sm transition-colors duration-150 ${
                        isDropActive
                          ? 'text-[var(--color-primary)] font-medium'
                          : 'text-[var(--color-text-muted)] hover:text-[var(--color-text)]'
                      }`}
                    >
                      {item.label}
                    </a>
                  );
                })}
              </div>
            )}

          </div>
        );
      })}

      {/* Mobile CTA */}
      <div class="pt-4">
        <a
          href={cta.href}
          class="block w-full text-center px-6 py-3 text-base font-semibold bg-white text-[var(--color-primary)] rounded-sm transition-all duration-200 hover:brightness-110"
        >
          {cta.text}
        </a>
      </div>

    </div>
  </div>
</header>

<script>
  // ── Sticky Shadow beim Scrollen ──
  const header = document.getElementById('nav-header');
  if (header) {
    const onScroll = () => {
      if (window.scrollY > 10) {
        header.classList.add('shadow-md');
        header.classList.remove('border-b');
      } else {
        header.classList.remove('shadow-md');
        header.classList.add('border-b');
      }
    };
    window.addEventListener('scroll', onScroll, { passive: true });
  }

  // ── Mobile Menu: Open / Close ──
  const hamburger = document.getElementById('nav-hamburger') as HTMLButtonElement | null;
  const mobileMenu = document.getElementById('nav-mobile-menu');

  function openMenu() {
    mobileMenu?.classList.remove('hidden');
    hamburger?.setAttribute('aria-expanded', 'true');
    hamburger?.setAttribute('aria-label', 'Menü schließen');
    hamburger?.classList.add('nav-open');
  }

  function closeMenu() {
    mobileMenu?.classList.add('hidden');
    hamburger?.setAttribute('aria-expanded', 'false');
    hamburger?.setAttribute('aria-label', 'Menü öffnen');
    hamburger?.classList.remove('nav-open');
  }

  if (hamburger && mobileMenu) {
    hamburger.addEventListener('click', () => {
      const isOpen = !mobileMenu.classList.contains('hidden');
      isOpen ? closeMenu() : openMenu();
    });

    // ESC-Taste schließt Menü
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !mobileMenu.classList.contains('hidden')) {
        closeMenu();
        hamburger.focus();
      }
    });

    // Klick außerhalb schließt Menü
    document.addEventListener('click', (e) => {
      if (
        !mobileMenu.classList.contains('hidden') &&
        !mobileMenu.contains(e.target as Node) &&
        !hamburger.contains(e.target as Node)
      ) {
        closeMenu();
      }
    });
  }

  // ── Akkordeon für Mobile Dropdowns ──
  document.querySelectorAll('[data-accordion-trigger]').forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const idx = trigger.getAttribute('data-index');
      const content = document.querySelector(`[data-accordion-content][data-index="${idx}"]`);
      const chevron = trigger.querySelector('[data-chevron]');
      if (!content) return;

      const isOpen = !content.classList.contains('hidden');
      if (isOpen) {
        content.classList.add('hidden');
        chevron?.classList.remove('rotate-180');
      } else {
        content.classList.remove('hidden');
        chevron?.classList.add('rotate-180');
      }
    });
  });
</script>

<style>
  /* Hamburger → X Animation */
  #nav-hamburger.nav-open .hamburger-bar:nth-child(1) {
    transform: translateY(8px) rotate(45deg);
  }
  #nav-hamburger.nav-open .hamburger-bar:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  #nav-hamburger.nav-open .hamburger-bar:nth-child(3) {
    transform: translateY(-8px) rotate(-45deg);
  }

  /* Aktiver Link – dezenter Unterstrich */
  [aria-current="page"] {
    text-decoration: underline;
    text-decoration-color: var(--color-secondary);
    text-underline-offset: 4px;
    text-decoration-thickness: 2px;
  }
</style>
