---
type SocialPlatform = 'instagram' | 'facebook' | 'linkedin' | 'youtube' | 'tiktok' | 'xing' | 'twitter';

interface FooterColumn {
  headline: string;
  links: { label: string; href: string }[];
}

interface Props {
  logo?: { src?: string; alt: string; text?: string; height?: number };
  description?: string;
  columns?: FooterColumn[];
  contact?: { address?: string; phone?: string; email?: string };
  socialLinks?: { platform: SocialPlatform; href: string }[];
  legalLinks: { label: string; href: string }[];
  copyright: string;
}

const {
  logo,
  description,
  columns = [],
  contact,
  socialLinks = [],
  legalLinks,
  copyright,
} = Astro.props;

const bg = 'bg-[var(--color-primary)]';
const textColor = 'text-white';
const mutedColor = 'text-white/70';
const borderColor = 'border-white/20';
const linkHover = 'hover:text-white transition-colors';

