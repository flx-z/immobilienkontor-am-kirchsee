---

<footer class={`${bg} ${textColor}`}>
  {/* Haupt-Bereich */}
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10">

      {/* Spalte 1: Logo + Beschreibung + Social */}
      <div class="lg:col-span-1">
        {logo && (
          <div class="mb-4 flex items-center gap-2">
            {logo.src && (
              <img src={logo.src} alt={logo.alt || ''} style={`height: ${logo.height ?? 48}px`} class="w-auto object-contain" />
            )}
            {logo.text && !logo.src && (
              <span class={`text-lg font-bold ${textColor}`}>{logo.text}</span>
            )}
          </div>
        )}
        {description && (
          <p class={`text-sm leading-relaxed ${mutedColor} mb-5`}>{description}</p>
        )}
        {socialLinks.length > 0 && (
          <div class="flex gap-3 flex-wrap">
            {socialLinks.map((sl) => (
              <a
                href={sl.href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={sl.platform}
                class={`w-8 h-8 rounded-full flex items-center justify-center ${mutedColor} hover:text-[var(--color-primary)] transition-colors`}
              >
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <Fragment set:html={socialIcons[sl.platform]} />
                </svg>
              </a>
            ))}
          </div>
        )}
      </div>

      {/* Navigations-Spalten */}
      {columns.map((col) => (
        <div>
          <h3 class={`text-xs font-semibold tracking-widest uppercase mb-4 ${mutedColor}`}>
            {col.headline}
          </h3>
          <ul class="space-y-2">
            {col.links.map((link) => (
              <li>
                <a href={link.href} class={`text-sm ${textColor} ${linkHover}`}>
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}

      {/* Kontakt-Spalte */}
      {contact && (
        <div>
          <h3 class={`text-xs font-semibold tracking-widest uppercase mb-4 ${mutedColor}`}>
            Kontakt
          </h3>
          <ul class="space-y-2">
            {contact.address && (
              <li class={`text-sm ${mutedColor} whitespace-pre-line`}>{contact.address}</li>
            )}
            {contact.phone && (
              <li>
                <a href={`tel:${contact.phone.replace(/\s/g, '')}`} class={`text-sm ${textColor} ${linkHover}`}>
                  {contact.phone}
                </a>
              </li>
            )}
            {contact.email && (
              <li>
                <a href={`mailto:${contact.email}`} class={`text-sm ${textColor} ${linkHover}`}>
                  {contact.email}
                </a>
              </li>
            )}
          </ul>
        </div>
      )}

    </div>
  </div>

  {/* Untere Zeile */}
  <div class={`border-t ${borderColor}`}>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class={`text-xs ${mutedColor}`}>{copyright}</p>
      <div class="flex flex-wrap gap-4">
        {legalLinks.map((link) => (
          <a href={link.href} class={`text-xs ${mutedColor} ${linkHover}`}>
            {link.label}
          </a>
        ))}
        <button
          type="button"
          onclick="window.__showCookieBanner?.()"
          class={`text-xs ${mutedColor} ${linkHover} bg-transparent border-none cursor-pointer p-0`}
        >
          Cookie-Einstellungen
        </button>
      </div>
    </div>
  </div>
</footer>
